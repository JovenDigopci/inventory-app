  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/JovenDigopci/inventory-app/issues"
  },
  "homepage": "https://github.com/JovenDigopci/inventory-app#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5"
  }
}
