{
  "name": "inventory-app",
  "version": "1.0.0",
  "description": "This application is for managing inventory for a decant perfume shop.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "migrate": "node src/scripts/migrate.js",
    "seed": "node src/scripts/seed.js",
    "test": "node --test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JovenDigopci/inventory-app.git"
  },
  "keywords": [],
